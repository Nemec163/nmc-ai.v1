# nmc-ai.v1 example config

MODE=infra

# infra mode
OPENCLAW_PASSWORD="CHANGE_ME"
TAILSCALE_AUTH_MODE=interactive
# TAILSCALE_AUTHKEY="tskey-auth-..."
EXTRA_SSH_KEYS=""

# openclaw mode
OPENCLAW_ONBOARD=interactive
OPENCLAW_PROVIDER=
OPENCLAW_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional override installer URLs (space-separated)
# OPENCLAW_OFFICIAL_INSTALLER_URLS="https://install.openclaw.ai/installer.sh https://openclaw.ai/install.sh"
